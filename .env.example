WEBHOOK_SECRET=
TRIGGER_MENTION=@forge-ai

# Local Forgejo bootstrap credentials.
FORGEJO_BOOTSTRAP_USER=forge-ai
FORGEJO_BOOTSTRAP_PASSWORD=forge-ai-password
FORGEJO_BOOTSTRAP_EMAIL=forge-ai@example.invalid
FORGEJO_BOOTSTRAP_REPO=demo
FORGEJO_DEV_USER=forge-user
FORGEJO_DEV_PASSWORD=user-password
FORGEJO_DEV_EMAIL=forge-user@example.invalid

# Default Compose agent is a no-credential mock for smoke testing.
AGENT_COMMAND=forge-ai-mock-agent

# Real agents. Install and log in to these CLIs on your host.
# AGENT_COMMAND=
# AGENT_BIN=codex
# AGENT_ALLOW_GIT=false
# AGENT_ARGS="exec --sandbox workspace-write"
#
# AGENT_COMMAND=
# AGENT_BIN=claude
# AGENT_ARGS="--dangerously-skip-permissions --allowedTools Bash,Read,Write,Edit,MultiEdit,Glob,Grep -p"
#
# AGENT_COMMAND=
# AGENT_BIN=opencode
# AGENT_ARGS=run

# Subscription auth is preferred in dev. Run one of:
# codex login
# claude
# opencode
#
# API keys are still possible, but do not set ANTHROPIC_API_KEY when you want
# Claude subscription auth; Claude Code gives the API key precedence.
